\newcommand{\figref}[1]{Figure~\ref{fig:#1}}
\newcommand{\tabref}[1]{Table~\ref{tab:#1}}
\newcommand{\equref}[1]{Equation~\eqref{eq:#1}}

%% Code
\newcommand{\code}[1]{\texttt{#1}}
